{
  "expo": {
    "name": "cook-dex",
    "slug": "cook-dex",
    "scheme": "cook-dex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFB347"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFB347"
      },
      "androidNavigationBar": {
        "backgroundColor": "#000000"
      },
      "package": "com.cookdex.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Cook-Dex(쿡덱스)가 식재료를 스캔하기 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": "동영상 레시피 기록 등을 위해 마이크 접근 권한이 필요합니다."
        }
      ]
    ],
    "extra": {
      "eas": {}
    }
  }
}